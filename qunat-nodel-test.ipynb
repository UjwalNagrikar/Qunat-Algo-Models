# ═══════════════════════════════════════════════════════════════════════
# 2.  CONFIG  ← edit here
# ═══════════════════════════════════════════════════════════════════════
SYMBOL          = "RELIANCE.NS"
TIMEFRAME       = "1d"              # DAILY — yfinance supports 8yr daily
LOOKBACK_YEARS  = 8                 # years of history
INITIAL_CAPITAL = 1_000_000        # ₹ 10 Lakh

# ── Donchian Channel (PURE PRICE ACTION) ────────────────────────────
N_BAR           = 20               # N-bar channel lookback
#
#   Long  signal : close breaks ABOVE  highest high of last N bars
#   Short signal : close breaks BELOW  lowest  low  of last N bars
#   Stop  (long) : lowest  low  of last N bars at entry (dc_low)
#   Stop  (short): highest high of last N bars at entry (dc_high)
#   TP           : entry ± TARGET_R × risk (price-based, R-multiple)

# ── Risk Management ──────────────────────────────────────────────────
RISK_PCT        = 0.02             # 2% capital risked per trade
MAX_LOTS        = 10               # cap on lot size
MARGIN_UTIL     = 0.60             # 60% margin utilisation
COOLDOWN        = 2                # bars of cooling off after exit

# ── Take Profit ──────────────────────────────────────────────────────
USE_TARGET      = True
TARGET_R        = 2.0              # TP = 2 × risk distance (2R)

# ── NSE Charges — Zerodha 2024 ──────────────────────────────────────
BROKERAGE       = 20.0
STT_RATE        = 0.000125
EXCH_RATE       = 0.000019
SEBI_RATE       = 0.000001
STAMP_RATE      = 0.00002
GST_RATE        = 0.18

# ── Monte Carlo ──────────────────────────────────────────────────────
MC_RUNS         = 1_000
MC_RUIN_LVL     = 0.50

# ── Output ───────────────────────────────────────────────────────────
OUT_DIR         = "/mnt/user-data/outputs"   # Colab: change to "/content"
IST             = pytz.timezone("Asia/Kolkata")

# ═══════════════════════════════════════════════════════════════════════
# 3.  VALIDATE
# ═══════════════════════════════════════════════════════════════════════
if SYMBOL not in DB:
    raise ValueError(f"'{SYMBOL}' not in DB. Add it or pick from DB keys.")
LOT_SIZE, MARGIN_LOT, STOCK_NAME = DB[SYMBOL]
LOOKBACK_DAYS = 365 * LOOKBACK_YEARS

# ═══════════════════════════════════════════════════════════════════════
# 4.  HELPERS
# ═══════════════════════════════════════════════════════════════════════
def charges(price: float, qty: float, side: str) -> float:
    """Full NSE futures charge stack (Zerodha 2024)."""
    tv  = abs(price * qty)
    brk = BROKERAGE
    stt = tv * STT_RATE   if side == "SELL" else 0.0
    exc = tv * EXCH_RATE
    sbi = tv * SEBI_RATE
    stp = tv * STAMP_RATE if side == "BUY"  else 0.0
    gst = (brk + exc + sbi) * GST_RATE
    return brk + stt + exc + sbi + stp + gst


def lot_size(capital: float, entry_px: float, stop_px: float) -> int:
    """
    Risk-based position sizing.
      lots_risk   = floor( capital * RISK_PCT / risk_per_lot )
      lots_margin = floor( capital * MARGIN_UTIL / MARGIN_LOT )
      final       = min(lots_risk, lots_margin, MAX_LOTS)
    """
    risk_per_share = abs(entry_px - stop_px)
    if risk_per_share <= 0:
        return 0
    risk_per_lot  = risk_per_share * LOT_SIZE
    lots_risk     = int(capital * RISK_PCT / risk_per_lot)
    lots_margin   = int(capital * MARGIN_UTIL / MARGIN_LOT)
    lots          = min(lots_risk, lots_margin, MAX_LOTS)
    if lots == 0 and lots_margin >= 1:
        lots = 1                   # always trade at least 1 lot if margin ok
    return max(lots, 0)


# ═══════════════════════════════════════════════════════════════════════
# 5.  DATA  — 8 years daily
# ═══════════════════════════════════════════════════════════════════════
print(f"\n{'═'*68}")
print(f"  {STOCK_NAME}  ({SYMBOL})")
print(f"  Pure Price Action  ·  {N_BAR}-Bar Donchian Breakout")
print(f"  {LOOKBACK_YEARS}-Year Daily Backtest  ·  Full NSE Charges")
print(f"{'═'*68}")

end   = dt.datetime.now(tz=pytz.utc)
start = end - dt.timedelta(days=LOOKBACK_DAYS + 90)      # buffer for channel warmup

raw = yf.download(
    SYMBOL, start=start, end=end,
    interval=TIMEFRAME, auto_adjust=True, progress=False
)
if raw.empty:
    sys.exit("No data returned — check symbol / network.")

if isinstance(raw.columns, pd.MultiIndex):
    raw.columns = raw.columns.get_level_values(0)
raw.rename(
    columns={"Open":"o","High":"h","Low":"l","Close":"c","Volume":"v"},
    inplace=True
)
raw = raw[["o","h","l","c","v"]].copy()

# Convert to IST
if raw.index.tzinfo is None:
    raw.index = raw.index.tz_localize("UTC")
raw.index = raw.index.tz_convert(IST)

# Trim to exactly LOOKBACK_YEARS
cutoff = raw.index[-1] - pd.Timedelta(days=LOOKBACK_DAYS)
df = raw.loc[raw.index >= cutoff].copy()

# ═══════════════════════════════════════════════════════════════════════
# 6.  DONCHIAN CHANNEL  (zero indicators — pure OHLCV)
# ═══════════════════════════════════════════════════════════════════════
#
#  KEY: shift(1) before rolling → channel is formed on PREVIOUS N bars
#       so today's bar can "break out" above/below it without lookahead
#
df["dc_high"] = df["h"].shift(1).rolling(N_BAR).max()   # prev-N highest high
df["dc_low"]  = df["l"].shift(1).rolling(N_BAR).min()   # prev-N lowest  low
df["dc_mid"]  = (df["dc_high"] + df["dc_low"]) / 2      # channel midpoint

df.dropna(inplace=True)

# ── Signals ──────────────────────────────────────────────────────────
df["long_sig"]  = df["c"] > df["dc_high"]   # close breaks ABOVE channel → LONG
df["short_sig"] = df["c"] < df["dc_low"]    # close breaks BELOW channel → SHORT

nl = int(df["long_sig"].sum())
ns = int(df["short_sig"].sum())
print(f"\n  Bars: {len(df)}   Long signals: {nl}   Short signals: {ns}")
print(f"  Date range: {df.index[0].date()} → {df.index[-1].date()}\n")

# ═══════════════════════════════════════════════════════════════════════
# 7.  BACKTEST ENGINE
# ═══════════════════════════════════════════════════════════════════════
cap      = INITIAL_CAPITAL
side     = None
epx      = 0.0       # entry price
stop_px  = 0.0       # stop loss (channel extreme at entry)
tp_px    = 0.0       # take profit (2R from entry)
etime    = None
nlots    = 0
qty      = 0.0
cdl      = 0

eq_curve  = []
pnls      = []
trades    = []
total_chg = 0.0
tno       = 0

for i in range(len(df)):
    row = df.iloc[i]
    bt  = df.index[i]
    o, h, l, c = float(row["o"]), float(row["h"]), float(row["l"]), float(row["c"])
    dc_h = float(row["dc_high"])
    dc_l = float(row["dc_low"])
    dc_m = float(row["dc_mid"])
    if cdl > 0: cdl -= 1

    # ── EXIT CHECK ────────────────────────────────────────────────────
    if side:
        xpx = None; xrsn = None

        # 1. Stop loss — channel extreme hit intrabar
        if side == "LONG"  and l <= stop_px:
            xpx = round(stop_px, 2); xrsn = "SL"
        elif side == "SHORT" and h >= stop_px:
            xpx = round(stop_px, 2); xrsn = "SL"

        # 2. Take profit — 2R target hit intrabar
        if xpx is None and USE_TARGET:
            if side == "LONG"  and h >= tp_px:
                xpx = round(tp_px, 2); xrsn = "TP"
            elif side == "SHORT" and l <= tp_px:
                xpx = round(tp_px, 2); xrsn = "TP"

        # 3. Channel midpoint exit (early mean-reversion cut)
        if xpx is None:
            if side == "LONG"  and c <= dc_m:
                xpx = round(c, 2); xrsn = "MID"
            elif side == "SHORT" and c >= dc_m:
                xpx = round(c, 2); xrsn = "MID"

        # 4. Opposite breakout → flip
        if xpx is None:
            if   side == "LONG"  and row["short_sig"]:
                xpx = round(c, 2); xrsn = "FLIP"
            elif side == "SHORT" and row["long_sig"]:
                xpx = round(c, 2); xrsn = "FLIP"

        if xpx is not None:
            grs  = (xpx - epx) * qty * (1 if side == "LONG" else -1)
            chg  = charges(xpx, qty, "SELL" if side == "LONG" else "BUY")
            net  = grs - chg
            cap += net; total_chg += chg; pnls.append(net); tno += 1
            try:   bh = i - list(df.index).index(etime)
            except: bh = 0
            trades.append(dict(
                no=tno, side=side,
                edate=str(etime)[:10], xdate=str(bt)[:10], bh=bh,
                epx=epx, xpx=xpx, stop=stop_px, tp=tp_px,
                lots=nlots, qty=int(qty),
                notional=round(epx * qty),
                gross=round(grs, 2), chg=round(chg, 2), net=round(net, 2),
                cap=round(cap), xrsn=xrsn
            ))
            side=None; nlots=0; qty=0.0; etime=None; cdl=COOLDOWN

    # ── ENTRY CHECK ───────────────────────────────────────────────────
    if not side and cdl == 0:
        sig = "LONG" if row["long_sig"] else ("SHORT" if row["short_sig"] else None)
        if sig:
            # Stop placed at the channel extreme (pure price, no % arbitrary)
            s_px = dc_l if sig == "LONG" else dc_h
            lots = lot_size(cap, o, s_px)
            if lots > 0:
                risk_dist  = abs(o - s_px)
                if risk_dist <= 0:
                    risk_dist = o * 0.005       # fallback: 0.5%

                epx     = round(o, 2)
                stop_px = round(s_px, 2)
                tp_px   = round(epx + TARGET_R * risk_dist, 2) \
                          if sig == "LONG" \
                          else round(epx - TARGET_R * risk_dist, 2)
                side    = sig
                etime   = bt
                nlots   = lots
                qty     = lots * LOT_SIZE
                chg     = charges(epx, qty, "BUY" if side == "LONG" else "SELL")
                total_chg += chg; cap -= chg

    # ── EQUITY SNAPSHOT ───────────────────────────────────────────────
    unr = (c - epx) * qty * (1 if side == "LONG" else -1) if side else 0.0
    eq_curve.append(cap + unr)

# ═══════════════════════════════════════════════════════════════════════
# 8.  METRICS
# ═══════════════════════════════════════════════════════════════════════
equity  = pd.Series(eq_curve, index=df.index)
rets    = equity.pct_change().dropna()
dd_ser  = (equity / equity.cummax() - 1) * 100

tot_ret = (equity.iloc[-1] / INITIAL_CAPITAL - 1) * 100
max_dd  = dd_ser.min()
wins    = [p for p in pnls if p > 0]
losses  = [p for p in pnls if p < 0]
wr      = len(wins) / len(pnls) * 100 if pnls else 0
aw      = np.mean(wins)   if wins   else 0
al      = np.mean(losses) if losses else 0
pf      = sum(wins) / abs(sum(losses)) if losses else float("inf")
sharpe  = (rets.mean() / rets.std()) * np.sqrt(252) if rets.std() > 0 else 0
exp     = (wr / 100 * aw) + ((1 - wr / 100) * al)
pct_chg = total_chg / INITIAL_CAPITAL * 100

cw = cl = mcw = mcl = 0
for p in pnls:
    if p > 0: cw += 1; cl = 0; mcw = max(mcw, cw)
    else:     cl += 1; cw = 0; mcl = max(mcl, cl)

xrsn_cnt = {}
for t in trades:
    xrsn_cnt[t["xrsn"]] = xrsn_cnt.get(t["xrsn"], 0) + 1

